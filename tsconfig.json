{
  "compilerOptions": {
    "target": "ES2024",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowJs": false,
    "noEmitOnError": true,
    "incremental": true,
    "tsBuildInfoFile": "dist/frontend/.tsbuildinfo",
    "sourceMap": false
  },
  "include": ["frontend/src/**/*.ts", "frontend/src/vite-env.d.ts", "shared/**/*.ts"],
  "exclude": ["node_modules", "dist", "tauri"]
}
