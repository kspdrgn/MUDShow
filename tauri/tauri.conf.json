{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MUDShow",
  "version": "1.0.0",
  "identifier": "com.mudshow.app",
  "build": {
    "beforeDevCommand": "npm run dev:frontend",
    "beforeBuildCommand": "npm run build:frontend",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist/frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "MUDShow",
        "width": 1280,
        "height": 860,
        "decorations": false,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
