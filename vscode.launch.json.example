{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Chrome",
            "request": "launch",
            "type": "chrome",
            "url": "http://localhost:8080",
            "webRoot": "${workspaceFolder}"
        },
        {
            "type": "lldb",
            "request": "attach",
            "name": "Attach Rust to Tauri",
            "pid": "${command:pickProcess}",
            "cwd": "${workspaceFolder}",
            "sourceLanguages": [
                "rust"
            ]
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Launch Frontend (Vite)",
            "url": "http://127.0.0.1:5173",
            "webRoot": "${workspaceFolder}/frontend",
            "sourceMapPathOverrides": {
                "/@fs/*": "${workspaceFolder}/*",
                "/src/*": "${workspaceFolder}/frontend/src/*"
            }
        },
        {
            "type": "node-terminal",
            "request": "launch",
            "name": "Start Tauri Dev",
            "command": "npm run tauri:dev"
        },
        {
            "type": "chrome",
            "request": "attach",
            "name": "Attach to Tauri WebView",
            "port": 9222,
            "webRoot": "${workspaceFolder}/frontend",
            "sourceMapPathOverrides": {
                "/@fs/*": "${workspaceFolder}/*",
                "/src/*": "${workspaceFolder}/frontend/src/*"
            }
        }
    ],
    "compounds": [
        {
            "name": "Debug Tauri Full Stack",
            "configurations": [
                "Start Tauri Dev",
                "Attach Rust to Tauri"
            ]
        },
        {
            "name": "Debug Tauri UI + Rust",
            "configurations": [
                "Start Tauri Dev",
                "Attach WebView2 to Tauri",
                "Attach Rust to Tauri"
            ]
        }
    ]
}
