{
  "name": "mudshow",
  "version": "1.0.0",
  "description": "MUDShow!",
  "type": "module",
  "packageManager": "pnpm@11.0.7",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "start": "pnpm tauri:dev",
    "dev": "pnpm tauri:dev",
