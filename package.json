    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^25.9.3",
    "rimraf": "^6.1.3",
    "svelte": "^5.56.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
